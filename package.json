{
  "name": "no-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev app",
    "build": "next build app",
    "start": "next start app",
    "lint": "next lint app",
    "test": "ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "postinstall": "node scripts/patch-zama-timeout.cjs",
    "contracts:install": "cd packages/foundry && forge soldeer install",
    "contracts:build": "cd packages/foundry && forge build",
    "contracts:arc:build": "powershell -ExecutionPolicy Bypass -File scripts/build-arc.ps1",
    "arc:circle:create-wallet": "node scripts/circle-arc-create-wallet.mjs",
    "arc:circle:wallet-info": "node scripts/circle-arc-wallet-info.mjs",
    "deploy:sepolia": "powershell -ExecutionPolicy Bypass -File packages/foundry/scripts/deploy-sepolia.ps1",
    "deploy:arc": "powershell -ExecutionPolicy Bypass -File scripts/deploy-arc.ps1",
    "deploy:arc:circle": "npm run contracts:arc:build && node scripts/circle-arc-deploy-uma-oov2.mjs",
    "deploy:arc:circle:mock": "npm run contracts:arc:build && node scripts/circle-arc-deploy.mjs",
    "subgraph:arc:codegen": "cd subgraphs/nomarket-arc && npm run codegen",
    "subgraph:arc:build": "cd subgraphs/nomarket-arc && npm run build",
    "subgraph:arc:deploy": "cd subgraphs/nomarket-arc && npm run deploy",
    "subgraph:zama:codegen": "cd subgraphs/nomarketzama && npm run codegen",
    "subgraph:zama:build": "cd subgraphs/nomarketzama && npm run build",
    "subgraph:zama:deploy": "cd subgraphs/nomarketzama && npm run deploy"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@swc/helpers": "^0.5.23",
    "@tanstack/react-query": "^5.90.12",
    "@zama-fhe/react-sdk": "^3.0.0",
    "@zama-fhe/sdk": "^3.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.5",
    "viem": "^2.38.3",
    "wagmi": "^2.19.2"
  },
  "devDependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.6.0",
    "@circle-fin/smart-contract-platform": "^10.6.0",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@uma/contracts-node": "^0.4.28",
    "autoprefixer": "^10.4.19",
    "chai": "^4.5.0",
    "mocha": "^11.7.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
